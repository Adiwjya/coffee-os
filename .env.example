# --- Database (Supabase or any Postgres) ---
# Supabase: Project Settings -> Database -> Connection string -> URI (Session pooler)
# Example: postgresql://postgres.xxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- Better Auth ---
# Generate with one of:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL where this app is served. In dev keep as http://localhost:3000.
BETTER_AUTH_URL=http://localhost:3000

# --- Supabase client (optional, only if you call Supabase APIs directly from the browser) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
